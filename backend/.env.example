# Theme Intelligence Dashboard Backend - Configuration

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_HOST=localhost
FLASK_PORT=5001

# Database
DATABASE_PATH=theme_intel.db

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# yfinance Configuration
YFINANCE_CACHE_MINUTES=15
YFINANCE_PERIOD=1y
YFINANCE_INTERVAL=1wk

# Signal Detection Configuration
SIGNAL_PRICE_MOVE_THRESHOLD=3.0
SIGNAL_52WEEK_DISTANCE=5.0
SIGNAL_RSI_PERIOD=14
SIGNAL_RSI_OVERSOLD=30
SIGNAL_RSI_OVERBOUGHT=70

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Feature Flags
ENABLE_SECTOR_RRG=true
ENABLE_THEME_MANAGEMENT=true
ENABLE_SIGNAL_DETECTION=true
ENABLE_MARKET_OVERVIEW=true
